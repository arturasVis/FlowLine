@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <a class="sidebar-brand" href="/">
            <span class="brand-mark">▚</span>
            <span class="brand-text">FlowLine</span>
        </a>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-heading">Operations</span>
                <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    <span>Stations</span>
                </NavLink>
                <AuthorizeView Policy="@FlowLinePolicies.CanManage">
                    <NavLink class="nav-item" href="/admin/orders">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-4"/><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M8 12h8M8 16h5"/></svg>
                        <span>Orders</span>
                    </NavLink>
                    <NavLink class="nav-item" href="/admin/import">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
                        <span>Import Orders</span>
                    </NavLink>
                </AuthorizeView>
            </div>

            <AuthorizeView Policy="@FlowLinePolicies.CanViewReports">
                <div class="nav-section">
                    <span class="nav-heading">Configuration</span>
                    <NavLink class="nav-item" href="/admin/workflows">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="12" r="2.5"/><path d="M8.5 6H14a1.5 1.5 0 0 1 1.5 1.5v3M8.5 18H14a1.5 1.5 0 0 0 1.5-1.5v-3"/></svg>
                        <span>Workflows</span>
                    </NavLink>
                    <AuthorizeView Policy="@FlowLinePolicies.CanManage" Context="mgr">
                        <NavLink class="nav-item" href="/admin/stations">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"/><circle cx="9" cy="7" r="2.5" fill="currentColor" stroke="none"/><line x1="4" y1="17" x2="20" y2="17"/><circle cx="15" cy="17" r="2.5" fill="currentColor" stroke="none"/></svg>
                            <span>Manage Stations</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/admin/assignments">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11l-3 3-2-2"/></svg>
                            <span>Assign Workflows</span>
                        </NavLink>
                    </AuthorizeView>
                </div>

                <div class="nav-section">
                    <span class="nav-heading">Analytics</span>
                    <NavLink class="nav-item" href="/admin/timing">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5M9 2h6"/></svg>
                        <span>Timing</span>
                    </NavLink>
                </div>
            </AuthorizeView>
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <div class="user-chip">
                    <span class="user-name">@context.User.Identity?.Name</span>
                    <span class="user-level">@LevelLabel(context.User)</span>
                </div>
                <form method="post" action="/auth/logout" class="logout-form">
                    <button type="submit" class="logout-button">Sign out</button>
                </form>
            </AuthorizeView>
        </div>
    </aside>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private static string LevelLabel(System.Security.Claims.ClaimsPrincipal user) =>
        user.FindFirst(FlowLineClaims.Level)?.Value switch
        {
            "3" => "Manager",
            "2" => "Advanced",
            _ => "Staff",
        };
}
