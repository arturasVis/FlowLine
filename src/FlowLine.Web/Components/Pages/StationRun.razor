@page "/station/{StationId:int}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IRelayService Relay
@inject IRelayNotifier Notifier
@inject IAssignmentService Assignments
@inject NavigationManager Nav

<PageTitle>@(_station?.Name ?? "Station")</PageTitle>

@if (_notFound)
{
    <p>Station @StationId not found.</p>
}
else if (_station is null)
{
    <p>Loading...</p>
}
else
{
    <div class="station" tabindex="0" @ref="_rootElement" @onkeydown="HandleKeyDown">
        <header class="station-header">
            <h1>@_station.Name</h1>
            <span class="station-path">@_station.Stage.Workflow.Name - @_station.Stage.Name</span>
            <span class="queue-depth">Queue: @_queueDepth waiting</span>
        </header>

        @if (_activeWorkItem is null)
        {
            @if (ShowPrebuildScan)
            {
                <div class="prebuild-scan">
                    <p>Scan or enter a prebuild ID or order number to start a unit.</p>
                    <input @ref="_prebuildInput" @bind="_prebuildEntry" @bind:event="oninput"
                           placeholder="Prebuild ID"
                           @onkeydown="HandlePrebuildKey" @onkeydown:stopPropagation="true" />
                    <button @onclick="StartFromPrebuildAsync" disabled="@(_advancing || string.IsNullOrWhiteSpace(_prebuildEntry))">
                        Start build
                    </button>
                    @if (_errorMessage is not null)
                    {
                        <p class="error">@_errorMessage</p>
                    }
                </div>
            }
            else if (ShowStageScan)
            {
                <div class="prebuild-scan">
                    <p>Scan the unit's order number to claim it at this stage.</p>
                    <input @ref="_stageScanInput" @bind="_stageScanEntry" @bind:event="oninput"
                           placeholder="Order number"
                           @onkeydown="HandleStageScanKey" @onkeydown:stopPropagation="true" />
                    <button @onclick="StartFromStageScanAsync" disabled="@(_advancing || string.IsNullOrWhiteSpace(_stageScanEntry))">
                        Claim unit
                    </button>
                    @if (_errorMessage is not null)
                    {
                        <p class="error">@_errorMessage</p>
                    }
                </div>
            }
            else if (ShowAdHocStart)
            {
                <div class="idle">
                    <p>Free-run workflow - start a run to do and time the steps.</p>
                    <button class="advance" @onclick="StartAdHocAsync" disabled="@_advancing">Start run (Enter)</button>
                    @if (_errorMessage is not null)
                    {
                        <p class="error">@_errorMessage</p>
                    }
                </div>
            }
            else if (_holdAutoClaim)
            {
                <div class="idle">
                    <p>Unit released. Auto-claim is paused so it isn't grabbed straight back.</p>
                    <button class="advance" @onclick="ResumeAsync">Resume (Enter)</button>
                </div>
            }
            else
            {
                <div class="idle">
                    <p>No units waiting. Idle.</p>
                </div>
            }
        }
        else
        {
            <div class="order-header">
                <span>Order #@_activeWorkItem.OrderNumber</span>
                <span>SKU @_activeWorkItem.Sku</span>
                <span>Qty @_activeWorkItem.Quantity</span>
                @if (!string.IsNullOrWhiteSpace(_activeWorkItem.Channel))
                {
                    <span>@_activeWorkItem.Channel</span>
                }
            </div>

            @if (_currentStep is not null)
            {
                <div class="step">
                    <p class="progress">Step @(_stepIndex + 1) of @_totalSteps</p>
                    <h2>@_currentStep.Name</h2>
                    <p class="instructions">@_currentStep.Instructions</p>

                    @if (_currentStep.MediaAssets.Count > 0)
                    {
                        <div class="media">
                            @foreach (var media in _currentStep.MediaAssets.OrderBy(m => m.DisplayOrder))
                            {
                                <img src="@($"/media/{media.FilePath}")" alt="@_currentStep.Name" />
                            }
                        </div>
                    }

                    @if (_currentStep.Inputs.Count > 0)
                    {
                        <div class="step-inputs">
                            @foreach (var input in _currentStep.Inputs.OrderBy(i => i.OrderIndex))
                            {
                                <div class="step-input">
                                    <label class="input-label">@input.Label @(input.Required ? "*" : "")</label>
                                    @switch (input.Type)
                                    {
                                        case StepInputType.Text:
                                            <input @bind="_inputText[input.Id]" @bind:event="oninput"
                                                   @onkeydown:stopPropagation="true" placeholder="Enter value…" />
                                            break;
                                        case StepInputType.Number:
                                            <input type="number" step="any" @bind="_inputText[input.Id]" @bind:event="oninput"
                                                   @onkeydown:stopPropagation="true" placeholder="Enter number…" />
                                            break;
                                        case StepInputType.PassFail:
                                            <div class="passfail">
                                                <button type="button" class="pf @(_inputText[input.Id] == "Pass" ? "pf-pass-on" : "")"
                                                        @onclick="() => SetPassFail(input.Id, true)">Pass</button>
                                                <button type="button" class="pf @(_inputText[input.Id] == "Fail" ? "pf-fail-on" : "")"
                                                        @onclick="() => SetPassFail(input.Id, false)">Fail</button>
                                            </div>
                                            break;
                                        case StepInputType.Checklist:
                                            <div class="checklist">
                                                @foreach (var opt in ChecklistItems(input))
                                                {
                                                    <label class="check">
                                                        <input type="checkbox" checked="@_inputChecks[input.Id].Contains(opt)"
                                                               @onchange="e => ToggleCheck(input.Id, opt, e)" /> @opt
                                                    </label>
                                                }
                                            </div>
                                            break;
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <button class="advance" @onclick="() => AdvanceAsync()" disabled="@(_advancing || !AllRequiredFilled)">
                    Advance@(_currentStep.Inputs.Count == 0 ? " (Enter)" : "")
                </button>
            }

            <div class="unit-actions">
                <button class="unit-action" @onclick="ReleaseAsync" disabled="@_advancing"
                        title="Put this unit back in the queue (progress is kept) and pause auto-claim">
                    Release
                </button>
                @if (EarlierStages.Count > 0)
                {
                    <button class="unit-action" @onclick="() => _showSendBack = !_showSendBack" disabled="@_advancing">
                        Send back...
                    </button>
                }
                <button class="unit-action scrap" @onclick="ScrapAsync" disabled="@_advancing"
                        title="Failed and physically junked - removes the unit from the line">
                    @(_confirmScrap ? "Confirm scrap?" : "Scrap")
                </button>
            </div>

            @if (_showSendBack)
            {
                <div class="send-back-panel">
                    <span>Rework from:</span>
                    <select @bind="_sendBackTargetId">
                        @foreach (var stage in EarlierStages)
                        {
                            <option value="@stage.Id">@stage.Name</option>
                        }
                    </select>
                    <button class="unit-action" @onclick="SendBackAsync" disabled="@_advancing">Send back</button>
                    <span class="hint">Steps from that stage onward will be redone.</span>
                </div>
            }

            @if (_errorMessage is not null)
            {
                <p class="error">@_errorMessage</p>
            }
        }
    </div>
}

@code {
    [Parameter]
    public int StationId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Station? _station;
    private bool _notFound;
    private WorkItem? _activeWorkItem;
    private Step? _currentStep;
    private int _stepIndex;
    private int _totalSteps;
    private int _queueDepth;
    private bool _advancing;
    private string? _errorMessage;
    private ElementReference _rootElement;

    // Operator answers to the current step's inputs, seeded per step (indexer @bind needs the key
    // present up-front). _inputText covers Text/Number/PassFail; _inputChecks holds a checklist's
    // ticked items. Rebuilt each time the current step changes (see UpdateCurrentStep).
    private readonly Dictionary<int, string> _inputText = [];
    private readonly Dictionary<int, HashSet<string>> _inputChecks = [];

    private readonly SemaphoreSlim _dbGate = new(1, 1);

    private string _prebuildEntry = string.Empty;
    private ElementReference _prebuildInput;
    private bool _prebuildInputFocused;
    private string _stageScanEntry = string.Empty;
    private ElementReference _stageScanInput;
    private bool _stageScanFocused;
    private bool _focusRootPending;
    private int? _staffNumber;
    private bool _holdAutoClaim;
    private bool _showSendBack;
    private int _sendBackTargetId;
    private bool _confirmScrap;

    private List<Stage> EarlierStages =>
        _station is null
            ? []
            : _station.Stage.Workflow.Stages
                .Where(s => s.OrderIndex < _station.Stage.OrderIndex)
                .OrderByDescending(s => s.OrderIndex)
                .ToList();

    private bool IsEntryStage =>
        _station is not null
        && _station.Stage.OrderIndex == _station.Stage.Workflow.Stages.Min(s => s.OrderIndex);

    private bool ShowPrebuildScan =>
        _station is not null && _activeWorkItem is null
        && _station.Stage.Workflow.RequiresPrebuild && IsEntryStage;

    private bool ShowAdHocStart =>
        _station is not null && _activeWorkItem is null
        && _station.Stage.Workflow.AllowAdHocStart && IsEntryStage;

    private bool ShowStageScan =>
        _station is not null && _activeWorkItem is null
        && _station.Stage.RequiresScan && !ShowPrebuildScan && !ShowAdHocStart;

    protected override async Task OnInitializedAsync()
    {
        Notifier.StageChanged += OnStageChanged;

        await _dbGate.WaitAsync();
        try
        {
            _station = await Relay.GetStationAsync(StationId);
            if (_station is null)
            {
                _notFound = true;
                return;
            }

            var user = AuthState is null ? null : (await AuthState).User;
            _staffNumber = user?.GetStaffNumber() is int n and > 0 ? n : null;
            if (user is not null && user.GetLevel() <= AccessLevel.Staff)
            {
                var assigned = await Assignments.GetAssignedWorkflowIdsAsync(user.GetStaffNumber());
                if (!assigned.Contains(_station.Stage.WorkflowId))
                {
                    Nav.NavigateTo("/");
                    return;
                }
            }

            await RefreshAsync();
        }
        finally
        {
            _dbGate.Release();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _station is not null)
        {
            await _rootElement.FocusAsync();
        }

        if (ShowPrebuildScan && !_prebuildInputFocused)
        {
            _prebuildInputFocused = true;
            await _prebuildInput.FocusAsync();
        }

        if (ShowStageScan && !_stageScanFocused)
        {
            _stageScanFocused = true;
            await _stageScanInput.FocusAsync();
        }

        if (_focusRootPending)
        {
            _focusRootPending = false;
            await _rootElement.FocusAsync();
        }
    }

    private async Task RefreshAsync()
    {
        if (_station is null)
        {
            return;
        }

        _activeWorkItem = await Relay.GetActiveWorkItemAsync(_station.Id);

        var entryStationNoAutoClaim =
            IsEntryStage && (_station.Stage.Workflow.RequiresPrebuild || _station.Stage.Workflow.AllowAdHocStart);
        if (_activeWorkItem is null && !_holdAutoClaim && !entryStationNoAutoClaim && !_station.Stage.RequiresScan)
        {
            _activeWorkItem = await Relay.ClaimNextAsync(_station.Id);
        }

        _queueDepth = await Relay.GetQueueDepthAsync(_station.StageId);
        _prebuildInputFocused = false;
        _stageScanFocused = false;
        _showSendBack = false;
        _confirmScrap = false;

        UpdateCurrentStep();
    }

    private void UpdateCurrentStep()
    {
        var orderedSteps = _station!.Stage.Steps.OrderBy(s => s.OrderIndex).ToList();
        _totalSteps = orderedSteps.Count;

        if (_activeWorkItem is null)
        {
            _currentStep = null;
            _stepIndex = 0;
            return;
        }

        var completedStepIds = _activeWorkItem.StepCompletions.Select(sc => sc.StepId).ToHashSet();
        _currentStep = orderedSteps.FirstOrDefault(s => !completedStepIds.Contains(s.Id));
        _stepIndex = _currentStep is null ? orderedSteps.Count : orderedSteps.FindIndex(s => s.Id == _currentStep.Id);

        SeedInputState();
    }

    // Fresh, empty answer state for the current step's inputs. Rebuilt on every step change so a
    // previous step's entries don't leak, and every bound key exists before the input renders.
    private void SeedInputState()
    {
        _inputText.Clear();
        _inputChecks.Clear();
        if (_currentStep is null)
        {
            return;
        }
        foreach (var input in _currentStep.Inputs)
        {
            _inputText[input.Id] = string.Empty;
            if (input.Type == StepInputType.Checklist)
            {
                _inputChecks[input.Id] = [];
            }
        }
    }

    private static IEnumerable<string> ChecklistItems(StepInput input) =>
        string.IsNullOrWhiteSpace(input.Options)
            ? []
            : input.Options.Replace("\r\n", "\n").Split('\n').Where(l => l.Trim().Length > 0);

    private void ToggleCheck(int inputId, string option, ChangeEventArgs e)
    {
        var set = _inputChecks[inputId];
        if (e.Value is true) { set.Add(option); } else { set.Remove(option); }
    }

    private void SetPassFail(int inputId, bool pass) => _inputText[inputId] = pass ? "Pass" : "Fail";

    // The value each input contributes (checklist = ticked items joined), used for both the
    // "all required filled" gate and the payload sent to AdvanceAsync.
    private string InputValue(StepInput input) => input.Type == StepInputType.Checklist
        ? string.Join('\n', ChecklistItems(input).Where(o => _inputChecks[input.Id].Contains(o)))
        : (_inputText.GetValueOrDefault(input.Id) ?? string.Empty).Trim();

    private bool AllRequiredFilled =>
        _currentStep is null || _currentStep.Inputs
            .Where(i => i.Required)
            .All(i => InputValue(i).Length > 0);

    private List<StepInputValue> BuildInputValues() =>
        _currentStep is null
            ? []
            : _currentStep.Inputs.Select(i => new StepInputValue(i.Id, InputValue(i))).ToList();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
        {
            return;
        }
        if (_activeWorkItem is null && _holdAutoClaim)
        {
            await ResumeAsync();
            return;
        }
        if (ShowAdHocStart)
        {
            await StartAdHocAsync();
            return;
        }
        // Steps with inputs advance only via the button — Enter would fire mid-typing.
        if (_currentStep is not null && _currentStep.Inputs.Count > 0)
        {
            return;
        }
        await AdvanceAsync();
    }

    private async Task HandleStageScanKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_stageScanEntry))
        {
            await StartFromStageScanAsync();
        }
    }

    private async Task ResumeAsync()
    {
        _holdAutoClaim = false;
        await RunGuardedAsync(RefreshAsync);
    }

    private async Task ReleaseAsync()
    {
        _holdAutoClaim = true;
        await RunUnitActionAsync(async () =>
        {
            try
            {
                await Relay.ReleaseAsync(_activeWorkItem!.Id, _station!.Id);
            }
            catch
            {
                _holdAutoClaim = false;
                throw;
            }
        });
    }

    private async Task SendBackAsync()
    {
        if (_sendBackTargetId == 0)
        {
            _sendBackTargetId = EarlierStages.FirstOrDefault()?.Id ?? 0;
        }
        var targetId = _sendBackTargetId;
        await RunUnitActionAsync(() => Relay.SendBackAsync(_activeWorkItem!.Id, _station!.Id, targetId));
    }

    private async Task ScrapAsync()
    {
        if (!_confirmScrap)
        {
            _confirmScrap = true;
            return;
        }
        await RunUnitActionAsync(() => Relay.ScrapAsync(_activeWorkItem!.Id, _station!.Id));
    }

    private async Task RunUnitActionAsync(Func<Task> action)
    {
        if (_advancing || _activeWorkItem is null || _station is null)
        {
            return;
        }

        _advancing = true;
        _errorMessage = null;
        await _dbGate.WaitAsync();
        try
        {
            await action();
            await RefreshAsync();
        }
        catch (RelayOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (DbUpdateConcurrencyException)
        {
            _errorMessage = "This unit changed elsewhere - refreshed.";
            await RefreshAsync();
        }
        finally
        {
            _dbGate.Release();
            _advancing = false;
        }
    }

    private async Task HandlePrebuildKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await StartFromPrebuildAsync();
        }
    }

    private async Task StartFromPrebuildAsync()
    {
        if (_advancing || _station is null || string.IsNullOrWhiteSpace(_prebuildEntry))
        {
            return;
        }

        _advancing = true;
        _errorMessage = null;
        await _dbGate.WaitAsync();
        try
        {
            await Relay.CreateFromPrebuildAsync(_station.Id, _prebuildEntry);
            _prebuildEntry = string.Empty;
            await RefreshAsync();
            _focusRootPending = true;
        }
        catch (RelayOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _dbGate.Release();
            _advancing = false;
        }
    }

    private async Task StartFromStageScanAsync()
    {
        if (_advancing || _station is null || string.IsNullOrWhiteSpace(_stageScanEntry))
        {
            return;
        }

        _advancing = true;
        _errorMessage = null;
        await _dbGate.WaitAsync();
        try
        {
            await Relay.ClaimByScanAsync(_station.Id, _stageScanEntry);
            _stageScanEntry = string.Empty;
            await RefreshAsync();
            _focusRootPending = true;
        }
        catch (RelayOperationException ex)
        {
            _errorMessage = ex.Message;
            _stageScanEntry = string.Empty;
            _stageScanFocused = false;
        }
        finally
        {
            _dbGate.Release();
            _advancing = false;
        }
    }

    private async Task StartAdHocAsync()
    {
        if (_advancing || _station is null)
        {
            return;
        }

        _advancing = true;
        _errorMessage = null;
        await _dbGate.WaitAsync();
        try
        {
            await Relay.StartAdHocAsync(_station.Id);
            await RefreshAsync();
        }
        catch (RelayOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _dbGate.Release();
            _advancing = false;
        }
    }

    private async Task AdvanceAsync()
    {
        if (_advancing || _activeWorkItem is null || _station is null)
        {
            return;
        }

        _advancing = true;
        _errorMessage = null;
        await _dbGate.WaitAsync();
        try
        {
            await Relay.AdvanceAsync(_activeWorkItem.Id, _station.Id, _staffNumber, BuildInputValues());
            await RefreshAsync();
        }
        catch (RelayOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (DbUpdateConcurrencyException)
        {
            _errorMessage = "This unit was already advanced elsewhere - refreshed.";
            await RefreshAsync();
        }
        finally
        {
            _dbGate.Release();
            _advancing = false;
        }
    }

    private void OnStageChanged(int stageId)
    {
        if (_station is null || stageId != _station.StageId)
        {
            return;
        }

        _ = InvokeAsync(() => RunGuardedAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        }));
    }

    private async Task RunGuardedAsync(Func<Task> work)
    {
        await _dbGate.WaitAsync();
        try
        {
            await work();
        }
        finally
        {
            _dbGate.Release();
        }
    }

    public ValueTask DisposeAsync()
    {
        Notifier.StageChanged -= OnStageChanged;
        _dbGate.Dispose();
        return ValueTask.CompletedTask;
    }
}
