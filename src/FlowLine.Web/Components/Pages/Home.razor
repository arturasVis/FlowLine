@page "/"
@rendermode InteractiveServer
@inject IRelayService Relay
@inject IAssignmentService Assignments

<PageTitle>FlowLine — Select Workflow</PageTitle>

<div class="station-select">
    <h1>Select a workflow</h1>

    @if (_workflows is null)
    {
        <p>Loading…</p>
    }
    else if (_workflows.Count == 0)
    {
        <p>No workflows are available to you yet. Ask a manager to assign one.</p>
    }
    else
    {
        <ul class="station-list">
            @foreach (var item in _workflows)
            {
                <li>
                    <a href="@($"/workflow/{item.Workflow.Id}")">
                        <span class="station-name">@item.Workflow.Name</span>
                        <span class="station-detail">
                            @item.StationCount station@(item.StationCount == 1 ? "" : "s")@(item.Workflow.RequiresPrebuild ? " · prebuild required" : "")
                        </span>
                    </a>
                </li>
            }
        </ul>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<(Workflow Workflow, int StationCount)>? _workflows;

    protected override async Task OnInitializedAsync()
    {
        var stations = await Relay.GetStationsAsync();

        // A workflow is runnable if it's active and has at least one station. Group the loaded
        // stations by their workflow to build the pick-list (identity resolution gives one
        // Workflow instance per id, so grouping by the reference is safe).
        var byWorkflow = stations
            .Where(s => s.Stage.Workflow.IsActive)
            .GroupBy(s => s.Stage.Workflow)
            .Select(g => (Workflow: g.Key, StationCount: g.Count()))
            .OrderBy(x => x.Workflow.Name)
            .ToList();

        // Level-1 staff only see workflows assigned to them; level 2/3 see all.
        var user = AuthState is null ? null : (await AuthState).User;
        if (user is not null && user.GetLevel() <= AccessLevel.Staff)
        {
            var assigned = await Assignments.GetAssignedWorkflowIdsAsync(user.GetStaffNumber());
            byWorkflow = byWorkflow.Where(x => assigned.Contains(x.Workflow.Id)).ToList();
        }

        _workflows = byWorkflow;
    }
}
