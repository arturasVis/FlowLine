@page "/admin/workflows/{WorkflowId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = FlowLinePolicies.CanManage)]
@using FlowLine.Application.Stations
@inject IWorkflowBuilderService Builder
@inject IStationService Stations

<PageTitle>@(_workflow?.Name ?? "Workflow") — Admin</PageTitle>

@if (_notFound)
{
    <p>Workflow @WorkflowId not found.</p>
}
else if (_workflow is null)
{
    <p>Loading…</p>
}
else
{
    <div class="admin-page">
        <p><a href="/admin/workflows">&larr; All workflows</a></p>

        <div class="workflow-header">
            <input @bind="_workflow.Name" placeholder="Name" />
            <input @bind="_workflow.Description" placeholder="Description" />
            <button @onclick="SaveWorkflowAsync">Save</button>
            <span class="status-badge">@(_workflow.IsActive ? "Active" : "Archived")</span>
        </div>

        <label class="prebuild-toggle">
            <input type="checkbox" checked="@_workflow.RequiresPrebuild" @onchange="TogglePrebuildAsync" />
            Requires a prebuild ID scanned at step 1
        </label>

        <label class="prebuild-toggle">
            <input type="checkbox" checked="@_workflow.AllowAdHocStart" @onchange="ToggleAdHocAsync" />
            Free-run / training mode — start runs without an order (entry station gets a "Start run" button)
        </label>

        @{
            var readiness = WorkflowReadiness.For(_workflow);
        }
        @if (readiness.IsRunnable)
        {
            <p class="readiness ready">✓ Ready to run</p>
        }
        else
        {
            <div class="readiness not-ready">
                <strong>⚠ Not ready to run:</strong>
                <ul>
                    @foreach (var problem in readiness.Problems)
                    {
                        <li>@problem</li>
                    }
                </ul>
            </div>
        }

        @if (_error is not null)
        {
            <p class="error">@_error</p>
        }

        @foreach (var stage in _workflow.Stages.OrderBy(s => s.OrderIndex).ToList())
        {
            <section class="stage-card">
                <header class="stage-card-header">
                    <input @bind="stage.Name" />
                    <button @onclick="() => SaveStageAsync(stage)">Save</button>
                    <label class="scan-flag" title="Operators must scan an order number to claim a queued unit at this stage">
                        <input type="checkbox" checked="@stage.RequiresScan" @onchange="e => ToggleStageScanAsync(stage, e)" />
                        Requires scan to claim
                    </label>
                    <button @onclick="() => MoveStageAsync(stage, -1)" disabled="@(stage.OrderIndex == 0)">Move stage up</button>
                    <button @onclick="() => MoveStageAsync(stage, 1)" disabled="@(stage.OrderIndex == _workflow.Stages.Count - 1)">Move stage down</button>
                    <button class="danger" @onclick="() => DeleteStageAsync(stage)">Delete stage</button>
                </header>

                @if (stage.Stations.Count == 0)
                {
                    <p class="stage-warning">⚠ No station mans this stage — units will stall here until you add one below.</p>
                }
                @if (stage.Steps.Count == 0)
                {
                    <p class="stage-warning">⚠ This stage has no steps yet.</p>
                }

                <div class="stage-stations">
                    <span class="stations-label">Stations:</span>
                    @foreach (var station in stage.Stations.OrderBy(s => s.Name).ToList())
                    {
                        <span class="station-chip">
                            <input @bind="station.Name" />
                            <button @onclick="() => SaveStationAsync(station)" title="Rename">Save</button>
                            <button class="danger" @onclick="() => DeleteStationAsync(station)" title="Remove station">✕</button>
                        </span>
                    }
                    <span class="add-station">
                        <input @bind="_newStationNames[stage.Id]" placeholder="New station name" />
                        <button @onclick="() => AddStationAsync(stage)">Add station</button>
                    </span>
                </div>

                @foreach (var step in stage.Steps.OrderBy(s => s.OrderIndex).ToList())
                {
                    <div class="step-card">
                        <input @bind="step.Name" placeholder="Step name" />
                        <textarea @bind="step.Instructions" placeholder="Instructions"></textarea>
                        <div class="step-card-actions">
                            <button @onclick="() => SaveStepAsync(step)">Save</button>
                            <button @onclick="() => MoveStepAsync(stage, step, -1)" disabled="@(step.OrderIndex == 0)">Move step up</button>
                            <button @onclick="() => MoveStepAsync(stage, step, 1)" disabled="@(step.OrderIndex == stage.Steps.Count - 1)">Move step down</button>
                            <button class="danger" @onclick="() => DeleteStepAsync(step)">Delete step</button>
                        </div>

                        <div class="media-list">
                            @foreach (var media in step.MediaAssets.OrderBy(m => m.DisplayOrder))
                            {
                                <div class="media-thumb">
                                    <img src="@($"/media/{media.FilePath}")" alt="" />
                                    <button class="danger" @onclick="() => DeleteMediaAsync(media)">Remove</button>
                                </div>
                            }
                            <InputFile OnChange="@(e => UploadMediaAsync(step, e))" />
                        </div>

                        <div class="inputs-editor">
                            <span class="inputs-label">Data the operator records:</span>
                            @foreach (var input in step.Inputs.OrderBy(i => i.OrderIndex).ToList())
                            {
                                <div class="input-row">
                                    <input @bind="input.Label" placeholder="Label" />
                                    <select @bind="input.Type">
                                        <option value="@StepInputType.Text">Text</option>
                                        <option value="@StepInputType.Number">Number</option>
                                        <option value="@StepInputType.PassFail">Pass / Fail</option>
                                        <option value="@StepInputType.Checklist">Checklist</option>
                                    </select>
                                    <label class="req-flag"><input type="checkbox" @bind="input.Required" /> required</label>
                                    @if (input.Type == StepInputType.Checklist)
                                    {
                                        <textarea @bind="input.Options" placeholder="One checklist item per line"></textarea>
                                    }
                                    <button @onclick="() => SaveInputAsync(input)">Save</button>
                                    <button @onclick="() => MoveInputAsync(step, input, -1)" disabled="@(input.OrderIndex == 0)">↑</button>
                                    <button @onclick="() => MoveInputAsync(step, input, 1)" disabled="@(input.OrderIndex == step.Inputs.Count - 1)">↓</button>
                                    <button class="danger" @onclick="() => DeleteInputAsync(input)" title="Remove input">✕</button>
                                </div>
                            }
                            <div class="add-input">
                                <input @bind="_newInputLabels[step.Id]" placeholder="New input label" />
                                <select @bind="_newInputTypes[step.Id]">
                                    <option value="@StepInputType.Text">Text</option>
                                    <option value="@StepInputType.Number">Number</option>
                                    <option value="@StepInputType.PassFail">Pass / Fail</option>
                                    <option value="@StepInputType.Checklist">Checklist</option>
                                </select>
                                <label class="req-flag"><input type="checkbox" @bind="_newInputRequired[step.Id]" /> required</label>
                                <button @onclick="() => AddInputAsync(step)">Add input</button>
                            </div>
                        </div>
                    </div>
                }

                <div class="add-row">
                    <input @bind="_newStepNames[stage.Id]" placeholder="New step name" />
                    <button @onclick="() => AddStepAsync(stage)">Add step</button>
                </div>
            </section>
        }

        <div class="add-row">
            <input @bind="_newStageName" placeholder="New stage name" />
            <button @onclick="AddStageAsync">Add stage</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public int WorkflowId { get; set; }

    private Workflow? _workflow;
    private bool _notFound;
    private string? _error;
    private string _newStageName = string.Empty;
    private readonly Dictionary<int, string> _newStepNames = [];
    private readonly Dictionary<int, string> _newStationNames = [];
    // Per-step "new input" draft (keyed by step id; seeded in LoadAsync for indexer @bind).
    private readonly Dictionary<int, string> _newInputLabels = [];
    private readonly Dictionary<int, StepInputType> _newInputTypes = [];
    private readonly Dictionary<int, bool> _newInputRequired = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _workflow = await Builder.GetWorkflowAsync(WorkflowId);
        _notFound = _workflow is null;

        if (_workflow is not null)
        {
            // @bind targets the dictionary indexer directly, so every stage needs an entry
            // up front — an indexer getter on a missing key would throw.
            foreach (var stage in _workflow.Stages)
            {
                _newStepNames.TryAdd(stage.Id, string.Empty);
                _newStationNames.TryAdd(stage.Id, string.Empty);
                foreach (var step in stage.Steps)
                {
                    _newInputLabels.TryAdd(step.Id, string.Empty);
                    _newInputTypes.TryAdd(step.Id, StepInputType.Text);
                    _newInputRequired.TryAdd(step.Id, false);
                }
            }
        }
    }

    private async Task AddInputAsync(Step step)
    {
        var label = _newInputLabels.GetValueOrDefault(step.Id, string.Empty);
        if (string.IsNullOrWhiteSpace(label))
        {
            return;
        }
        var type = _newInputTypes.GetValueOrDefault(step.Id, StepInputType.Text);
        var required = _newInputRequired.GetValueOrDefault(step.Id);
        await RunAsync(() => Builder.AddStepInputAsync(step.Id, label.Trim(), type, required, null));
        _newInputLabels[step.Id] = string.Empty;
        _newInputRequired[step.Id] = false;
        await LoadAsync();
    }

    private Task SaveInputAsync(StepInput input) =>
        RunAsync(() => Builder.UpdateStepInputAsync(input.Id, input.Label, input.Type, input.Required, input.Options));

    private async Task DeleteInputAsync(StepInput input)
    {
        await RunAsync(() => Builder.DeleteStepInputAsync(input.Id));
        await LoadAsync();
    }

    private async Task MoveInputAsync(Step step, StepInput input, int direction)
    {
        var ordered = step.Inputs.OrderBy(i => i.OrderIndex).Select(i => i.Id).ToList();
        var index = ordered.IndexOf(input.Id);
        var swapWith = index + direction;
        if (swapWith < 0 || swapWith >= ordered.Count)
        {
            return;
        }

        (ordered[index], ordered[swapWith]) = (ordered[swapWith], ordered[index]);
        await RunAsync(() => Builder.ReorderStepInputsAsync(step.Id, ordered));
        await LoadAsync();
    }

    private Task SaveWorkflowAsync() =>
        RunAsync(() => Builder.UpdateWorkflowAsync(_workflow!.Id, _workflow.Name, _workflow.Description));

    private async Task TogglePrebuildAsync(ChangeEventArgs e)
    {
        _workflow!.RequiresPrebuild = e.Value is true;
        // The two entry-mode flags are mutually exclusive; reflect the server-side clear locally.
        if (_workflow.RequiresPrebuild)
        {
            _workflow.AllowAdHocStart = false;
        }
        await RunAsync(() => Builder.SetWorkflowRequiresPrebuildAsync(_workflow.Id, _workflow.RequiresPrebuild));
    }

    private async Task ToggleAdHocAsync(ChangeEventArgs e)
    {
        _workflow!.AllowAdHocStart = e.Value is true;
        if (_workflow.AllowAdHocStart)
        {
            _workflow.RequiresPrebuild = false;
        }
        await RunAsync(() => Builder.SetWorkflowAllowAdHocStartAsync(_workflow.Id, _workflow.AllowAdHocStart));
    }

    private Task SaveStageAsync(Stage stage) =>
        RunAsync(() => Builder.UpdateStageAsync(stage.Id, stage.Name));

    private async Task ToggleStageScanAsync(Stage stage, ChangeEventArgs e)
    {
        stage.RequiresScan = e.Value is true;
        await RunAsync(() => Builder.SetStageRequiresScanAsync(stage.Id, stage.RequiresScan));
    }

    private async Task AddStationAsync(Stage stage)
    {
        var name = _newStationNames.GetValueOrDefault(stage.Id, string.Empty);
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        await RunAsync(() => Stations.CreateStationAsync(stage.Id, name.Trim()));
        _newStationNames[stage.Id] = string.Empty;
        await LoadAsync();
    }

    private Task SaveStationAsync(Station station) =>
        RunAsync(() => Stations.UpdateStationAsync(station.Id, station.Name));

    private async Task DeleteStationAsync(Station station)
    {
        await RunAsync(() => Stations.DeleteStationAsync(station.Id));
        await LoadAsync();
    }

    private Task SaveStepAsync(Step step) =>
        RunAsync(() => Builder.UpdateStepAsync(step.Id, step.Name, step.Instructions));

    private async Task AddStageAsync()
    {
        if (string.IsNullOrWhiteSpace(_newStageName))
        {
            return;
        }

        await RunAsync(() => Builder.AddStageAsync(_workflow!.Id, _newStageName.Trim()));
        _newStageName = string.Empty;
        await LoadAsync();
    }

    private async Task DeleteStageAsync(Stage stage)
    {
        await RunAsync(() => Builder.DeleteStageAsync(stage.Id));
        await LoadAsync();
    }

    private async Task MoveStageAsync(Stage stage, int direction)
    {
        var ordered = _workflow!.Stages.OrderBy(s => s.OrderIndex).Select(s => s.Id).ToList();
        var index = ordered.IndexOf(stage.Id);
        var swapWith = index + direction;
        if (swapWith < 0 || swapWith >= ordered.Count)
        {
            return;
        }

        (ordered[index], ordered[swapWith]) = (ordered[swapWith], ordered[index]);
        await RunAsync(() => Builder.ReorderStagesAsync(_workflow.Id, ordered));
        await LoadAsync();
    }

    private async Task AddStepAsync(Stage stage)
    {
        var name = _newStepNames.GetValueOrDefault(stage.Id, string.Empty);
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        await RunAsync(() => Builder.AddStepAsync(stage.Id, name.Trim(), string.Empty));
        _newStepNames[stage.Id] = string.Empty;
        await LoadAsync();
    }

    private async Task DeleteStepAsync(Step step)
    {
        await RunAsync(() => Builder.DeleteStepAsync(step.Id));
        await LoadAsync();
    }

    private async Task MoveStepAsync(Stage stage, Step step, int direction)
    {
        var ordered = stage.Steps.OrderBy(s => s.OrderIndex).Select(s => s.Id).ToList();
        var index = ordered.IndexOf(step.Id);
        var swapWith = index + direction;
        if (swapWith < 0 || swapWith >= ordered.Count)
        {
            return;
        }

        (ordered[index], ordered[swapWith]) = (ordered[swapWith], ordered[index]);
        await RunAsync(() => Builder.ReorderStepsAsync(stage.Id, ordered));
        await LoadAsync();
    }

    private async Task UploadMediaAsync(Step step, InputFileChangeEventArgs e)
    {
        const long maxFileSize = 10 * 1024 * 1024; // images/GIFs only, not video
        await RunAsync(async () =>
        {
            await using var stream = e.File.OpenReadStream(maxFileSize);
            await Builder.AddMediaAssetAsync(step.Id, e.File.Name, stream);
        });
        await LoadAsync();
    }

    private async Task DeleteMediaAsync(MediaAsset media)
    {
        await RunAsync(() => Builder.DeleteMediaAssetAsync(media.Id));
        await LoadAsync();
    }

    private async Task RunAsync(Func<Task> action)
    {
        _error = null;
        try
        {
            await action();
        }
        catch (WorkflowBuilderException ex)
        {
            _error = ex.Message;
        }
        catch (StationServiceException ex)
        {
            _error = ex.Message;
        }
        catch (IOException)
        {
            _error = "File too large (max 10 MB).";
        }
    }
}
