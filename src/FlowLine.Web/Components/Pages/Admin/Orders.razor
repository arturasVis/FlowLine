@page "/admin/orders"
@rendermode InteractiveServer
@implements IAsyncDisposable
@attribute [Authorize(Policy = FlowLinePolicies.CanManage)]
@inject IOrderService OrderService
@inject IWorkflowBuilderService Builder
@inject IRelayService Relay
@inject IRelayNotifier Notifier

<PageTitle>Orders — Admin</PageTitle>

<div class="admin-page">
    <h1>Orders</h1>

    <div class="new-order">
        <h2>New order</h2>
        <select @bind="_workflowId">
            <option value="0">Select a workflow…</option>
            @foreach (var workflow in _workflows ?? [])
            {
                <option value="@workflow.Id">@workflow.Name</option>
            }
        </select>
        <input @bind="_orderNumber" placeholder="Order #" />
        <input @bind="_sku" placeholder="SKU" />
        <input @bind="_quantity" type="number" min="1" placeholder="Qty" />
        <input @bind="_channel" placeholder="Channel (optional)" />
        <button @onclick="CreateAsync" disabled="@(!CanCreate)">Create</button>
    </div>

    @if (_error is not null)
    {
        <p class="error">@_error</p>
    }

    @if (_workItems is null)
    {
        <p>Loading…</p>
    }
    else if (_workItems.Count == 0)
    {
        <p>No orders yet.</p>
    }
    else
    {
        <table class="workflow-table">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>SKU</th>
                    <th>Qty</th>
                    <th>Channel</th>
                    <th>Workflow</th>
                    <th>Current stage</th>
                    <th>Status</th>
                    <th>Claimed by</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var workItem in _workItems)
                {
                    <tr>
                        <td><span class="mono">@workItem.OrderNumber</span></td>
                        <td><span class="mono">@workItem.Sku</span></td>
                        <td>@workItem.Quantity</td>
                        <td>@workItem.Channel</td>
                        <td>@workItem.Workflow.Name</td>
                        <td>@workItem.CurrentStage.Name</td>
                        <td>
                            <span class="status-pill @StatusClass(workItem.Status)">
                                <span class="status-dot"></span>@StatusLabel(workItem.Status)
                            </span>
                        </td>
                        <td>@(workItem.ClaimedByStation?.Name ?? "—")</td>
                        <td class="order-actions">
                            @if (workItem.Status == WorkItemStatus.InProgress)
                            {
                                <button class="unit-action" title="Free the claim — the unit re-queues at the back of its stage (progress kept)"
                                        @onclick="() => ReleaseAsync(workItem)">Release</button>
                            }
                            @if (workItem.Status is WorkItemStatus.Queued or WorkItemStatus.InProgress)
                            {
                                <button class="unit-action scrap" title="Void this order — it leaves the line and can be re-imported/scanned"
                                        @onclick="() => CancelAsync(workItem)">
                                    @(_confirmCancelId == workItem.Id ? "Confirm?" : "Cancel")
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Workflow>? _workflows;
    private List<WorkItem>? _workItems;
    private int _workflowId;
    private string _orderNumber = string.Empty;
    private string _sku = string.Empty;
    private int _quantity = 1;
    private string _channel = string.Empty;
    private string? _error;

    private bool CanCreate =>
        _workflowId > 0 && !string.IsNullOrWhiteSpace(_orderNumber) && !string.IsNullOrWhiteSpace(_sku) && _quantity > 0;

    private int? _confirmCancelId;

    private static string StatusClass(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Queued => "is-queued",
        WorkItemStatus.InProgress => "is-progress",
        WorkItemStatus.Completed => "is-done",
        WorkItemStatus.Cancelled => "is-void",
        WorkItemStatus.Scrapped => "is-void",
        _ => "",
    };

    private static string StatusLabel(WorkItemStatus status) => status switch
    {
        WorkItemStatus.InProgress => "In progress",
        _ => status.ToString(),
    };

    private async Task ReleaseAsync(WorkItem workItem)
    {
        _error = null;
        try
        {
            // Null station = admin override: no claim-ownership check.
            await Relay.ReleaseAsync(workItem.Id, null);
            await LoadWorkItemsAsync();
        }
        catch (RelayOperationException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CancelAsync(WorkItem workItem)
    {
        // Two-click confirm per row — cancelling is terminal.
        if (_confirmCancelId != workItem.Id)
        {
            _confirmCancelId = workItem.Id;
            return;
        }
        _confirmCancelId = null;
        _error = null;
        try
        {
            await OrderService.CancelWorkItemAsync(workItem.Id);
            await LoadWorkItemsAsync();
        }
        catch (OrderServiceException ex)
        {
            _error = ex.Message;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Live-refresh: RelayService raises StageChanged on every claim, hand-off, and prebuild
        // scan, so the list reflects units created/moved from station screens without a manual
        // reload — same mechanism the station screens use (see IRelayNotifier).
        Notifier.StageChanged += OnStageChanged;

        var allWorkflows = await Builder.GetWorkflowsAsync();
        // Only workflows that can actually accept an order — active and with at least one
        // stage to queue at — so picking one never hits OrderServiceException's "no stages" guard.
        _workflows = allWorkflows.Where(w => w.IsActive && w.Stages.Count > 0).ToList();

        await LoadWorkItemsAsync();
    }

    private void OnStageChanged(int stageId)
    {
        // The list spans all stages, so refresh on any change. InvokeAsync marshals back onto this
        // component's circuit (the event fires from whichever circuit triggered the change).
        _ = InvokeAsync(async () =>
        {
            await LoadWorkItemsAsync();
            StateHasChanged();
        });
    }

    public ValueTask DisposeAsync()
    {
        // Unsubscribe or we leak this component on the singleton notifier, which outlives the circuit.
        Notifier.StageChanged -= OnStageChanged;
        return ValueTask.CompletedTask;
    }

    private async Task LoadWorkItemsAsync()
    {
        _workItems = await OrderService.GetWorkItemsAsync();
    }

    private async Task CreateAsync()
    {
        _error = null;
        try
        {
            await OrderService.CreateWorkItemAsync(
                _workflowId,
                _orderNumber.Trim(),
                _sku.Trim(),
                _quantity,
                string.IsNullOrWhiteSpace(_channel) ? null : _channel.Trim());

            _orderNumber = string.Empty;
            _sku = string.Empty;
            _quantity = 1;
            _channel = string.Empty;
            await LoadWorkItemsAsync();
        }
        catch (OrderServiceException ex)
        {
            _error = ex.Message;
        }
    }
}
