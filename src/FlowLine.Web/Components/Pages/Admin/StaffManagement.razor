@page "/admin/staff"
@rendermode InteractiveServer
@attribute [Authorize(Policy = FlowLinePolicies.CanManage)]
@inject IStaffService Staff
@inject IAssignmentService Assignments
@inject IWorkflowBuilderService Builder

<PageTitle>Staff — Admin</PageTitle>

<div class="admin-page">
    <h1>Staff</h1>
    <p>Who can sign in and what they can do. The 4-digit staff number is the login code; level 1 runs assigned workflows, level 2 also views reports, level 3 manages everything.</p>

    <div class="new-station">
        <h2>New staff member</h2>
        <input @bind="_newNumber" type="number" min="1000" max="9999" placeholder="4-digit number" />
        <input @bind="_newName" placeholder="Name" />
        <select @bind="_newLevel">
            <option value="1">1 — Operator</option>
            <option value="2">2 — Advanced</option>
            <option value="3">3 — Manager</option>
        </select>
        <button @onclick="CreateAsync" disabled="@(!CanCreate)">Create</button>
    </div>

    @if (_error is not null)
    {
        <p class="error">@_error</p>
    }

    @if (_staff is null)
    {
        <p>Loading…</p>
    }
    else if (_staff.Count == 0)
    {
        <p>No staff members yet — create the first one above.</p>
    }
    else
    {
        <table class="workflow-table">
            <thead>
                <tr>
                    <th>Number</th>
                    <th>Name</th>
                    <th>Access level</th>
                    <th>Assigned workflows</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in _staff)
                {
                    <tr>
                        <td>@member.StaffNumber</td>
                        <td><input @bind="member.Name" /></td>
                        <td>
                            <select @bind="member.TestingPower">
                                <option value="1">1 — Operator</option>
                                <option value="2">2 — Advanced</option>
                                <option value="3">3 — Manager</option>
                            </select>
                        </td>
                        <td>
                            <span class="wf-summary">@AssignmentSummary(member.StaffNumber)</span>
                            <button class="wf-edit" @onclick="() => ToggleEditor(member.StaffNumber)">
                                @(_expandedStaff == member.StaffNumber ? "Close" : "Edit")
                            </button>
                        </td>
                        <td><button @onclick="() => SaveAsync(member)">Save</button></td>
                    </tr>
                    @if (_expandedStaff == member.StaffNumber)
                    {
                        <tr class="wf-panel-row">
                            <td colspan="5">
                                <div class="wf-panel">
                                    <input class="wf-filter" @bind="_workflowFilter" @bind:event="oninput"
                                           placeholder="Filter workflows…" />
                                    <div class="wf-checks">
                                        @foreach (var workflow in FilteredWorkflows())
                                        {
                                            <label>
                                                <input type="checkbox"
                                                       checked="@IsAssigned(member.StaffNumber, workflow.Id)"
                                                       @onchange="e => ToggleAssignmentAsync(workflow.Id, member.StaffNumber, e)" />
                                                @workflow.Name
                                            </label>
                                        }
                                        @if (!FilteredWorkflows().Any())
                                        {
                                            <span class="hint">No workflows match "@_workflowFilter".</span>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <p class="hint">Assignments only limit level-1 operators' station picker — levels 2 and 3 see every workflow regardless. Checkbox changes save immediately; Save applies name/level edits.</p>
        <p class="hint">Staff can't be deleted — their numbers are referenced by completion history. Drop someone to level 1 and unassign their workflows to lock them out of everything but sign-in.</p>
    }
</div>

@code {
    private List<StaffMember>? _staff;
    private List<Workflow>? _workflows;
    private readonly Dictionary<int, HashSet<int>> _assignedWorkflowIds = [];
    private int? _expandedStaff;
    private string _workflowFilter = string.Empty;
    private int? _newNumber;
    private string _newName = string.Empty;
    private int _newLevel = 1;
    private string? _error;

    private bool CanCreate => _newNumber is not null && !string.IsNullOrWhiteSpace(_newName);

    protected override async Task OnInitializedAsync()
    {
        _workflows = (await Builder.GetWorkflowsAsync()).Where(w => w.IsActive).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _staff = await Staff.GetStaffAsync();
        foreach (var member in _staff)
        {
            // A null TestingPower means level 1 everywhere else (AccessLevel.Normalize); give
            // the row's select a concrete value so it doesn't render an empty selection.
            member.TestingPower = AccessLevel.Normalize(member.TestingPower);
            _assignedWorkflowIds[member.StaffNumber] = await Assignments.GetAssignedWorkflowIdsAsync(member.StaffNumber);
        }
    }

    private bool IsAssigned(int staffNumber, int workflowId) =>
        _assignedWorkflowIds.TryGetValue(staffNumber, out var ids) && ids.Contains(workflowId);

    // Compact per-row summary — names when few, a count when many, so the table stays
    // readable no matter how many workflows exist. The full list lives in the expandable editor.
    private string AssignmentSummary(int staffNumber)
    {
        var names = (_workflows ?? [])
            .Where(w => IsAssigned(staffNumber, w.Id))
            .Select(w => w.Name)
            .ToList();
        return names.Count switch
        {
            0 => "None",
            <= 2 => string.Join(", ", names),
            _ => $"{names.Count} workflows",
        };
    }

    private void ToggleEditor(int staffNumber)
    {
        _expandedStaff = _expandedStaff == staffNumber ? null : staffNumber;
        _workflowFilter = string.Empty;
    }

    private IEnumerable<Workflow> FilteredWorkflows() =>
        (_workflows ?? []).Where(w =>
            string.IsNullOrWhiteSpace(_workflowFilter)
            || w.Name.Contains(_workflowFilter.Trim(), StringComparison.OrdinalIgnoreCase));

    private async Task ToggleAssignmentAsync(int workflowId, int staffNumber, ChangeEventArgs e)
    {
        var assigned = e.Value is bool value && value;
        await Assignments.SetAssignmentAsync(workflowId, staffNumber, assigned);
        if (_assignedWorkflowIds.TryGetValue(staffNumber, out var ids))
        {
            if (assigned) ids.Add(workflowId); else ids.Remove(workflowId);
        }
    }

    private async Task CreateAsync()
    {
        _error = null;
        try
        {
            await Staff.CreateStaffAsync(_newNumber!.Value, _newName, _newLevel);
            _newNumber = null;
            _newName = string.Empty;
            _newLevel = 1;
            await LoadAsync();
        }
        catch (StaffServiceException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveAsync(StaffMember member)
    {
        _error = null;
        try
        {
            await Staff.UpdateStaffAsync(member.StaffNumber, member.Name, AccessLevel.Normalize(member.TestingPower));
        }
        catch (StaffServiceException ex)
        {
            _error = ex.Message;
        }
    }
}
